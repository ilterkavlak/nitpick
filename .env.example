# Upstash Box API key (any one method below)
UPSTASH_BOX_API_KEY=

# Optional: macOS Keychain service name holding the key
NITPICK_BOX_KEYCHAIN_SERVICE=nitpick_upstash_box_api_key

# Optional: credentials file path (default: ~/.box/credentials)
NITPICK_BOX_CREDENTIALS_FILE=

# Optional: 1Password secret reference for the key
NITPICK_BOX_OP_REF=

# Optional: command that prints the key to stdout
NITPICK_BOX_API_KEY_COMMAND=

# GitHub read-only token (optional if `gh auth token` is available)
GITHUB_READ_TOKEN=

# GitHub review token (optional if `gh auth token` has PR write scope)
GITHUB_REVIEW_TOKEN=
