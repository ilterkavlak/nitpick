# Supply-chain hardening
# - Block lifecycle scripts unless explicitly allowed in package.json -> pnpm.onlyBuiltDependencies
ignore-scripts=true

# - Fail install if lockfile is out of date (no silent updates)
frozen-lockfile=true

# - Refuse to install packages younger than this many minutes (mitigates fresh malicious releases)
#   7 days. Bump or remove if it blocks a legitimate urgent upgrade.
min-release-age=10080

# - Strictly verify peer deps so a swap of an indirect dep cannot pass unnoticed
strict-peer-dependencies=true

# - Always resolve from the public registry (no fallback to a misconfigured mirror)
registry=https://registry.npmjs.org/

# - Refuse to run pnpm if it does not match the packageManager field in package.json
package-manager-strict=true

# - Save exact versions when adding deps via pnpm add
save-exact=false
save-prefix=^
